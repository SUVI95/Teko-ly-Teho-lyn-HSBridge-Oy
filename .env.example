# Copy to .env and fill in real values. Never commit .env.

NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

SESSION_SECRET=replace-with-long-random-string

# Required for /api/ai/chat, /api/ai/image, and module homework generators
OPENAI_API_KEY=

# Optional: /api/ai/claude (client ai-helper falls back to OpenAI if Claude fails)
ANTHROPIC_API_KEY=

# Optional bootstrap
SETUP_TOKEN=
ADMIN_PASSWORD=
