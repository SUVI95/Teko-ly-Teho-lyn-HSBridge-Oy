# Copy to .env and fill in real values. Never commit .env.

NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

SESSION_SECRET=replace-with-long-random-string

# Required for /api/ai/chat, /api/ai/image, transcription, and module homework generators
OPENAI_API_KEY=

# Voice interview feedback model (moduuli9 STAR / mock). Default: gpt-realtime-2
OPENAI_VOICE_MODEL=gpt-realtime-2

# Live mock interview — WebRTC Realtime API (browser voice-to-voice)
# marin = natural female (default); coral / shimmer = alternatives
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin

# Mock interview TTS fallback — wav = clearer than mp3
OPENAI_TTS_MODEL=gpt-4o-mini-tts-2025-03-20
OPENAI_TTS_VOICE=marin
OPENAI_TTS_FORMAT=wav
OPENAI_TTS_SPEED=0.97
# Optional: override delivery style (long single line)
# OPENAI_TTS_INSTRUCTIONS=

# Optional: /api/ai/claude (client ai-helper falls back to OpenAI if Claude fails)
ANTHROPIC_API_KEY=

# Public student portfolio pages (subdomain + clean URL)
PORTFOLIO_PUBLIC_HOST=portfolio.duunijobs.fi
PORTFOLIO_PUBLIC_PROTOCOL=https

# Optional bootstrap
SETUP_TOKEN=
ADMIN_PASSWORD=
